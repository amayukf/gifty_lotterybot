{
  "name": "lucky100",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "deploy": "tgcloud push",
    "db:migrate:tg": "tgcloud migrate",
    "run:tg": "tgcloud run",
    "worker:deploy": "wrangler deploy",
    "worker:dev": "wrangler dev",
    "worker:db:init": "wrangler d1 execute lucky100-db --remote --file=./migrations/0000_init.sql",
    "worker:db:init-local": "wrangler d1 execute lucky100-db --local --file=./migrations/0000_init.sql"
  },
  "dependencies": {
    "@libsql/client": "^0.8.0",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.31.3",
    "telegraf": "^4.16.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tgcloud/cli": "^0.1.2",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.111.0"
  }
}
